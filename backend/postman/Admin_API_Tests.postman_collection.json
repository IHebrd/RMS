  "item": [
    {
      "name": "01 - Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Admin login success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Token exists and role is admin', function () {",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.expect(json.data.user.role).to.eql('admin');",
              "});",
              "pm.collectionVariables.set('adminToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "02 - Create Organization With Logo",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Organization created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Organization id exists', function () {",
              "  pm.expect(json.data.id).to.exist;",
              "});",
              "pm.collectionVariables.set('organizationId', String(json.data.id));",
              "console.log('Logo is stored as text field. Use get organization by id to verify:', pm.collectionVariables.get('organizationLogo'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
