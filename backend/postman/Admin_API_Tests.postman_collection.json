        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Logo Organization\",\n  \"type\": \"private\",\n  \"description\": \"Organization created from Postman admin API test. Logo is stored as a string URL/path.\",\n  \"logo\": \"{{organizationLogo}}\",\n  \"governorate\": \"Tunis\",\n  \"delegation\": \"Tunis Centre\",\n  \"postal_code\": \"1000\",\n  \"address\": \"Rue Postman, Tunis\",\n  \"phone\": \"71123456\",\n  \"email\": \"contact.postman.org@test.tn\",\n  \"website\": \"https://postman-test-org.example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/organizations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "organizations"
          ]
        }
