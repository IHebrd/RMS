{
  "info": {
    "name": "RMS Admin API Tests",
    "_postman_id": "f1d91b6c-8b13-4cc0-9dbb-513f6b2d8a11",
    "description": "Postman collection for testing RMS admin APIs: login, organizations with logo field, responsables, admins, dashboard, and admin-wide read endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{adminToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'http://localhost:5000/api');",
          "if (!pm.collectionVariables.get('adminEmail')) pm.collectionVariables.set('adminEmail', 'admin@rms.com');",
          "if (!pm.collectionVariables.get('adminPassword')) pm.collectionVariables.set('adminPassword', 'Admin@123');",
          "if (!pm.collectionVariables.get('organizationLogo')) pm.collectionVariables.set('organizationLogo', 'https://placehold.co/240x120/png?text=RMS+Org');",
          "const suffix = Date.now();",
          "if (!pm.collectionVariables.get('responsableEmail')) pm.collectionVariables.set('responsableEmail', `responsable_${suffix}@postman.test`);",
          "if (!pm.collectionVariables.get('responsablePassword')) pm.collectionVariables.set('responsablePassword', 'Resp@123');",
          "if (!pm.collectionVariables.get('responsableCin')) pm.collectionVariables.set('responsableCin', String(suffix).slice(-8));",
          "if (!pm.collectionVariables.get('createdAdminEmail')) pm.collectionVariables.set('createdAdminEmail', `admin_${suffix}@postman.test`);",
          "if (!pm.collectionVariables.get('createdAdminPassword')) pm.collectionVariables.set('createdAdminPassword', 'Admin@123');",
          "if (!pm.collectionVariables.get('createdAdminCin')) pm.collectionVariables.set('createdAdminCin', String(suffix + 11).slice(-8));"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "adminEmail",
      "value": "admin@rms.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin@123"
    },
