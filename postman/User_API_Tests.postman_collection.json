{
  "info": {
    "name": "RMS User API Tests",
    "_postman_id": "bdf5746b-7cde-469d-8f9c-5f6e01f3b15a",
    "description": "Postman collection for testing the RMS user actor API: signup, login, profile, organizations, reclamations, tracking, messages, password change, and logout.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:5000/api');",
          "}",
          "if (!pm.collectionVariables.get('userEmail')) {",
          "  pm.collectionVariables.set('userEmail', `user_${Date.now()}@example.com`);",
          "}",
          "if (!pm.collectionVariables.get('userPassword')) {",
          "  pm.collectionVariables.set('userPassword', 'User@123');",
          "}",
          "if (!pm.collectionVariables.get('userCin')) {",
          "  pm.collectionVariables.set('userCin', String(Date.now()).slice(-8));",
          "}",
          "if (!pm.collectionVariables.get('organizationId')) {",
          "  pm.collectionVariables.set('organizationId', '1');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userEmail",
      "value": ""
    },
    {
      "key": "userPassword",
      "value": "User@123"
    },
    {
      "key": "userCin",
      "value": ""
    },
    {
      "key": "organizationId",
      "value": "1"
    },
    {
      "key": "reclamationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Signup User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Signup returns 201 or 409 if already exists', function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "if (pm.response.code === 201 && json.data && json.data.token) {",
              "  pm.collectionVariables.set('token', json.data.token);",
              "}",
              "if (pm.response.code === 201 && json.data && json.data.user && json.data.user.email) {",
              "  pm.collectionVariables.set('userEmail', json.data.user.email);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"confirm_password\": \"{{userPassword}}\",\n  \"first_name\": \"Postman\",\n  \"last_name\": \"User\",\n  \"phone\": \"50123456\",\n  \"cin\": \"{{userCin}}\",\n  \"address\": \"Rue de test, Tunis\",\n  \"governorate\": \"Tunis\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "02 - Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Response contains token', function () {",
              "  pm.expect(json.data.token).to.be.a('string');",
              "});",
              "pm.collectionVariables.set('token', json.data.token);",
              "pm.collectionVariables.set('userEmail', json.data.user.email);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
