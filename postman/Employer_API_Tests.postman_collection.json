{
  "info": {
    "name": "RMS Employer API Tests",
    "_postman_id": "aa3a48f7-f10d-44c7-bb8d-0ef6e6e1db59",
    "description": "Postman collection for testing RMS employer/employee APIs: login, dashboard, profile, tasks, lifecycle actions, proof upload, balance, and messages.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{employerToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'http://localhost:5000/api');",
          "if (!pm.collectionVariables.get('employerEmail')) pm.collectionVariables.set('employerEmail', 'mohamed.sassi@steg.tn');",
          "if (!pm.collectionVariables.get('employerPassword')) pm.collectionVariables.set('employerPassword', 'Resp@123');"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "employerEmail",
      "value": "mohamed.sassi@steg.tn"
    },
    {
      "key": "employerPassword",
      "value": "Resp@123"
    },
    {
      "key": "employerToken",
      "value": ""
    },
    {
      "key": "taskId",
      "value": ""
    },
    {
      "key": "proofId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Login Employer",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Employer login success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Token exists and role is employer', function () {",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.expect(json.data.user.role).to.eql('employer');",
              "});",
              "pm.collectionVariables.set('employerToken', json.data.token);",
              "pm.collectionVariables.set('employerEmail', json.data.user.email);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{employerEmail}}\",\n  \"password\": \"{{employerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "02 - Get Employer Dashboard",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Dashboard success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Dashboard data exists', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data).to.be.an('object');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "dashboard"
          ]
        }
      }
    },
    {
      "name": "03 - Get Employer Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Profile email exists', function () {",
              "  pm.expect(json.data.email).to.be.a('string');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "profile"
          ]
        }
      }
    },
    {
      "name": "04 - Update Employer Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile update success', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Employer\",\n  \"last_name\": \"Postman\",\n  \"phone\": \"97999999\",\n  \"skills\": [\"maintenance\", \"postman-test\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/employer/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "profile"
          ]
        }
      }
    },
    {
      "name": "05 - Upload Employer Avatar - Optional",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "avatar",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/employer/profile/avatar",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "profile",
            "avatar"
          ]
        },
        "description": "Optional. In Postman, choose a local image file for the form-data key `avatar` before sending."
      }
    },
    {
      "name": "06 - List My Tasks",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Tasks list success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Tasks array exists', function () {",
              "  pm.expect(json.data.tasks).to.be.an('array');",
              "});",
              "if (json.data.tasks.length > 0) {",
              "  pm.collectionVariables.set('taskId', String(json.data.tasks[0].id));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/tasks?page=1&limit=20",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "07 - Get Task Detail",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Task detail success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Task id matches variable', function () {",
              "  pm.expect(String(json.data.id)).to.eql(pm.collectionVariables.get('taskId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}"
          ]
        }
      }
    },
    {
      "name": "08 - Start Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Start succeeds only when task is assigned', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 400) console.log('Start can fail if task is already in_progress, completed, or failed.');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}/start",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}",
            "start"
          ]
        }
      }
    },
    {
      "name": "09 - Upload Task Proofs - Optional",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Proof upload succeeds when files are selected', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.data.proofs && json.data.proofs.length > 0) {",
              "    pm.collectionVariables.set('proofId', String(json.data.proofs[0].id));",
              "  }",
              "} else {",
              "  console.log('Select one or more local files for the form-data key `proofs` before sending.');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "description",
              "value": "Proof uploaded from Postman employer test.",
              "type": "text"
            },
            {
              "key": "proofs",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}/proofs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}",
            "proofs"
          ]
        },
        "description": "Optional. In Postman, choose an image/video file for the form-data key `proofs`. The backend accepts up to 10 files."
      }
    },
    {
      "name": "10 - Get Task Messages",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Messages success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Messages array exists', function () {",
              "  pm.expect(json.data.messages).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}",
            "messages"
          ]
        }
      }
    },
    {
      "name": "11 - Send Task Message",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Message sent', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hello, this is an employer message from Postman.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}",
            "messages"
          ]
        }
      }
    },
    {
      "name": "12 - Complete Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Complete succeeds if task is assigned or in progress', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 400) console.log('Complete can fail if task is already completed or failed.');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notes\": \"Task completed from Postman employer test.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}/complete",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}",
            "complete"
          ]
        }
      }
    },
    {
      "name": "13 - Fail Task - Alternative To Complete",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Fail endpoint responds', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 400) console.log('Fail can fail if task is already completed. Use this as an alternative path, not after completing the same task.');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Could not complete the task due to missing access.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/employer/tasks/{{taskId}}/fail",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "tasks",
            "{{taskId}}",
            "fail"
          ]
        },
        "description": "Alternative lifecycle path. Do not run this after completing the same task unless you expect a 400."
      }
    },
    {
      "name": "14 - Delete Own Proof - Optional",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete proof responds', function () {",
              "  pm.expect([200, 400, 403, 404]).to.include(pm.response.code);",
              "});",
              "console.log('Requires proofId from a successful proof upload and the task must not be completed.');"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/proofs/{{proofId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
            "proofs",
            "{{proofId}}"
          ]
        }
      }
    },
    {
      "name": "15 - Get Balance",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Balance success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Balance data exists', function () {",
              "  pm.expect(json.data).to.be.an('object');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employer/balance",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employer",
