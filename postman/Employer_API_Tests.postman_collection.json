    {
      "name": "16 - Change Password - Optional",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Password change responds', function () {",
              "  pm.expect([200, 400, 401]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) pm.collectionVariables.set('employerPassword', 'Employer@1234');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{employerPassword}}\",\n  \"new_password\": \"Employer@1234\",\n  \"confirm_password\": \"Employer@1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/change-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "change-password"
          ]
        },
        "description": "Optional. This changes the real password for the employer account, so skip it if you do not want to modify seeded/demo credentials."
      }
    },
    {
      "name": "17 - Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Logout success', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        }
      }
