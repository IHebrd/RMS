          "if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'http://localhost:5000/api');",
          "if (!pm.collectionVariables.get('responsableEmail')) pm.collectionVariables.set('responsableEmail', 'ahmed.benali@steg.tn');",
          "if (!pm.collectionVariables.get('responsablePassword')) pm.collectionVariables.set('responsablePassword', 'Resp@123');",
