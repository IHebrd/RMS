          "if (!pm.collectionVariables.get('employeeEmail')) pm.collectionVariables.set('employeeEmail', `employee_${suffix}@postman.test`);",
          "if (!pm.collectionVariables.get('employeePassword')) pm.collectionVariables.set('employeePassword', 'Emp@123');",
          "if (!pm.collectionVariables.get('employeeCin')) pm.collectionVariables.set('employeeCin', String(suffix).slice(-8));",
          "if (!pm.collectionVariables.get('bulkEmployeeEmail')) pm.collectionVariables.set('bulkEmployeeEmail', `bulk_employee_${suffix}@postman.test`);",
          "if (!pm.collectionVariables.get('bulkEmployeeCin')) pm.collectionVariables.set('bulkEmployeeCin', String(suffix + 17).slice(-8));"
        ]
      }
    }
