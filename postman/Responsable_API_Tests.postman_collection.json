      "name": "01 - Login Responsable",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Responsable login success', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Token exists and role is responsable', function () {",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.expect(json.data.user.role).to.eql('responsable');",
              "});",
              "pm.collectionVariables.set('responsableToken', json.data.token);",
              "pm.collectionVariables.set('responsableEmail', json.data.user.email);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{responsableEmail}}\",\n  \"password\": \"{{responsablePassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
