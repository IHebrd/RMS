      "name": "19 - Distribute Payment - Private/Association Only",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Payment responds', function () {",
              "  pm.expect([201, 400, 403]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 403) console.log('Expected for public organizations: public organizations cannot manage payments.');",
              "if (pm.response.code === 400) console.log('Amount must exactly match the reclamation amount. Adjust paymentAmount/distributions if needed.');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
